# d4s — DataForSEO credentials (copy to `.env` and fill in; `.env` is gitignored)
#
# Get an account: https://skq.pl/data4seo  (affiliate link)
#
# The client reads these from the process environment first, then from a `.env`
# file next to this package or in the current working directory. Process env
# always wins over the file.

DATAFORSEO_USERNAME=you@example.com
# Alias also accepted instead of DATAFORSEO_USERNAME:
# DATAFORSEO_LOGIN=you@example.com
DATAFORSEO_PASSWORD=your-api-password

# Optional — override the API base URL (defaults to https://api.dataforseo.com):
# DATAFORSEO_BASE_URL=https://api.dataforseo.com
